{
  "description": "noGlaze! hooks: output audit, pre-push gate, state checkpoint",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/prepush-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/audit-hook.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/precompact-checkpoint.sh",
            "timeout": 5
          },
          {
            "type": "prompt",
            "prompt": "[noGlaze! PreCompact] Audit state is being saved. After compaction, read ~/.noglaze/checkpoint.md to restore audit context. Do not skip quality checks — the audit trail persists even if your context doesn't."
          }
        ]
      }
    ]
  }
}
